<div class="container">
  <div class="card">
    <h1>Generador de Certificados</h1>
    <p class="subtitle">Sube tu archivo Excel y tu plantilla Word para generar los certificados automáticamente.</p>

    <%= form_with(url: certificates_create_path, method: :post, multipart: true, data: { turbo: false }) do |form| %>
      <div class="form-group">
        <%= form.label :excel_file, "1. Archivo Excel (.xlsx)", class: "form-label" %>
        <%= form.file_field :excel_file, accept: ".xlsx", required: true, class: "form-control" %>
      </div>

      <div class="form-group">
        <%= form.label :word_template, "2. Plantilla Word (.docx)", class: "form-label" %>
        <%= form.file_field :word_template, accept: ".docx", required: true, class: "form-control" %>
      </div>

      <div style="margin-top: 2rem;">
        <%= form.submit "Generar Certificados", class: "btn" %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="alert">
        <%= flash[:alert] %>
      </div>
    <% end %>
  </div>
</div>